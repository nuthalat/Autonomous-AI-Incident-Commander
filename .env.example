# Application
INCIDENT_COMMANDER_APP_NAME=Autonomous AI Incident Commander
INCIDENT_COMMANDER_ENVIRONMENT=development
INCIDENT_COMMANDER_DEBUG=false
INCIDENT_COMMANDER_LOG_LEVEL=INFO
INCIDENT_COMMANDER_LOG_JSON=true

# API
INCIDENT_COMMANDER_API_HOST=0.0.0.0
INCIDENT_COMMANDER_API_PORT=8000
INCIDENT_COMMANDER_CORS_ORIGINS=["http://localhost:3000"]

# Model selection: fake (default, no API key) | anthropic
INCIDENT_COMMANDER_MODEL_PROVIDER=fake
INCIDENT_COMMANDER_MODEL_NAME=fake-deterministic-v1
INCIDENT_COMMANDER_MODEL_TIMEOUT_SECONDS=60
INCIDENT_COMMANDER_MODEL_MAX_RETRIES=2

# Anthropic (only required when MODEL_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
INCIDENT_COMMANDER_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Investigation controls
INCIDENT_COMMANDER_DRY_RUN=true
INCIDENT_COMMANDER_READ_ONLY=true
INCIDENT_COMMANDER_MAX_REINVESTIGATION_LOOPS=2
INCIDENT_COMMANDER_MAX_AGENT_RETRIES=2
INCIDENT_COMMANDER_COST_BUDGET_USD=5.0

# PostgreSQL
INCIDENT_COMMANDER_DATABASE_URL=postgresql+asyncpg://incident:incident@localhost:5432/incident_commander
INCIDENT_COMMANDER_DATABASE_POOL_SIZE=5

# Redis
INCIDENT_COMMANDER_REDIS_URL=redis://localhost:6379/0

# Safety
INCIDENT_COMMANDER_APPROVAL_TOKEN_TTL_SECONDS=3600
INCIDENT_COMMANDER_PROMPT_INJECTION_FILTER=true

# Observability
INCIDENT_COMMANDER_OTEL_ENABLED=false
INCIDENT_COMMANDER_OTEL_SERVICE_NAME=incident-commander
INCIDENT_COMMANDER_OTEL_EXPORTER_ENDPOINT=http://localhost:4317
